# Copy this file to `.env` and fill in your PYRX workspace credentials.
#
# These are read by `app.config.ts` at build time and surfaced to the
# JS layer via `Constants.expoConfig.extra`. Re-run `npx expo prebuild`
# after changing these values.
#
# Values prefixed `EXPO_PUBLIC_` are intentionally readable by client
# code. Do NOT put server-only secrets here.

# Your PYRX workspace ID. Find it under Settings → Workspace in the
# PYRX dashboard.
EXPO_PUBLIC_PYRX_WORKSPACE_ID=wks_replace_me

# Your PYRX events / SDK API key. Use a `psk_test_` key for sandbox
# builds and `psk_live_` for production.
EXPO_PUBLIC_PYRX_API_KEY=psk_test_replace_me

# Wire-level environment. Use `sandbox` for development and `production`
# for App Store / TestFlight builds.
EXPO_PUBLIC_PYRX_ENVIRONMENT=sandbox

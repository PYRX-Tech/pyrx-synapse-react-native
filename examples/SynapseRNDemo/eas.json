{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false,
        "resourceClass": "m-medium"
      },
      "env": {
        "EXPO_PUBLIC_PYRX_ENVIRONMENT": "sandbox"
      }
    },
    "developmentSimulator": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true,
        "resourceClass": "m-medium"
      },
      "env": {
        "EXPO_PUBLIC_PYRX_ENVIRONMENT": "sandbox"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_PYRX_ENVIRONMENT": "sandbox"
      }
    },
    "production": {
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_PYRX_ENVIRONMENT": "production"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
